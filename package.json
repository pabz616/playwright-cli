  },
  "homepage": "https://github.com/pabz616/playwright-cli#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.2",
    "jest": "^29.7.0",
    "jest-playwright-preset": "^4.0.0",
